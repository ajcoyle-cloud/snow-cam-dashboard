# MeteoBlue API Configuration
# Sign up for a free account at https://my.meteoblue.com
# Free tier: 50 API calls per day
VITE_METEOBLUE_API_KEY=your_api_key_here

# Gemini (Google AI) — powers the forecast tab's "AI summary of the next 7 days".
# Free key (no credit card): https://aistudio.google.com/apikey
# Free tier: ~15 requests/min, 1,500/day on Flash models.
# IMPORTANT: no VITE_ prefix — this stays server-side (used only in
# api/forecast-summary.js) and is never shipped to the browser.
# Set this in your Vercel project's Environment Variables, not just locally.
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: pin a specific model (defaults to the free Flash alias).
# GEMINI_MODEL=gemini-flash-latest

# ElevenLabs — natural-sounding voice for the spoken forecast summary.
# Free key (no credit card): https://elevenlabs.io
# Free tier: ~10,000 characters/month (roughly 12-15 summaries).
# Optional: if unset (or the monthly quota runs out), the forecast tab
# automatically falls back to the browser's built-in speech synthesis, so the
# feature keeps working either way — this just makes it sound better.
# IMPORTANT: no VITE_ prefix — stays server-side (api/elevenlabs-tts.js only).
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
#
# IMPORTANT for free-tier accounts: the text-to-speech API rejects Voice
# Library voices with 402 "Free users cannot use library voices via the
# API" — free accounts can only use voices saved to their own "My Voices"
# list. If you have none there yet, open the ElevenLabs dashboard -> Voices
# -> Voice Library and click "Add to My Voices" on any voice (takes a
# click, no cost). The server automatically uses the first voice in your
# account, so no further config is needed once you've added one.
#
# Optional overrides:
# ELEVENLABS_VOICE_ID=your_voice_id_from_my_voices
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
