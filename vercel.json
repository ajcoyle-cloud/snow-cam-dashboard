{
  "rewrites": [
    {
      "source": "/ms-api/:path*",
      "destination": "https://www.metservice.com/publicData/webdata/:path*"
    },
    {
      "source": "/cam-archive/:path*",
      "destination": "https://webcams.whakapapa.com/:path*"
    },
    {
      "source": "/radar-feed/:path*",
      "destination": "https://weatherwatch-maps.s3.ap-southeast-2.amazonaws.com/metservice/rainradar-realtime/:path*"
    },
    {
      "source": "/pw-obs/:path*",
      "destination": "/api/pw-obs?path=:path*"
    },
    {
      "source": "/lyford-cam/:cam",
      "destination": "/api/lyford-cam?cam=:cam"
    },
    {
      "source": "/((?!whakapapa-snow-forecast\\.html|radar-test|assets|api).*)",
      "destination": "/index.html"
    }
  ]
}
