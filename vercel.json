{
  "headers": [
    {
      "source": "/whakapapa-snow-forecast.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/radar-map.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, max-age=0, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ms-api/:path*",
      "destination": "https://www.metservice.com/publicData/webdata/:path*"
    },
    {
      "source": "/cam-archive/:path*",
      "destination": "https://webcams.whakapapa.com/:path*"
    },
    {
      "source": "/radar-feed/:path*",
      "destination": "https://weatherwatch-maps.s3.ap-southeast-2.amazonaws.com/metservice/rainradar-realtime/:path*"
    },
    {
      "source": "/radar-feed-regional/:path*",
      "destination": "https://weatherwatch-maps.s3.ap-southeast-2.amazonaws.com/metservice/localrainradar-realtime/:path*"
    },
    {
      "source": "/pw-obs/:path*",
      "destination": "/api/pw-obs?path=:path*"
    },
    {
      "source": "/lyford-cam/:cam",
      "destination": "/api/lyford-cam?cam=:cam"
    },
    {
      "source": "/rainbow-cam/:cam",
      "destination": "/api/rainbow-cam?cam=:cam"
    },
    {
      "source": "/whakapapa-report",
      "destination": "/api/whakapapa-report"
    },
    {
      "source": "/forecast-summary",
      "destination": "/api/forecast-summary"
    },
    {
      "source": "/elevenlabs-tts",
      "destination": "/api/elevenlabs-tts"
    },
    {
      "source": "/cardrona-report",
      "destination": "/api/cardrona-report"
    },
    {
      "source": "/treblecone-report",
      "destination": "/api/treblecone-report"
    },
    {
      "source": "/mthutt-report",
      "destination": "/api/mthutt-report"
    },
    {
      "source": "/((?!whakapapa-snow-forecast\\.html|radar-map\\.html|radar-test|assets|api).*)",
      "destination": "/index.html"
    }
  ]
}
